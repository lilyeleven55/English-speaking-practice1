# 智谱 AI API Key 配置
#
# 获取方式：
# 1. 访问 https://bigmodel.cn
# 2. 注册并登录账号
# 3. 在用户中心 -> API Keys 页面创建 API Key
# 4. 将创建的 API Key 填入下方
#
# 注意：
# - 请勿将此文件（包含真实 API Key）提交到 Git
# - .gitignore 已包含 .env 文件，确保 .env 不被提交
# - 重命名此文件为 .env 并填入真实 Key

ZHIPU_API_KEY=your-api-key-here

# 示例（请替换为真实 Key）：
# ZHIPU_API_KEY=28292cdda5b24c43b257a4b453e267ad.cmFaN394KmanzsDU
